# ─── NextAuth ─────────────────────────────────────────────────────────────────
# Générer avec : openssl rand -base64 32
NEXTAUTH_SECRET=your_nextauth_secret_here

# URL de votre site en production (ex: https://mon-site.vercel.app)
# En développement laisser : http://localhost:3000
NEXTAUTH_URL=http://localhost:3000

# ─── Discord OAuth2 ───────────────────────────────────────────────────────────
# Discord Developer Portal > Your App > OAuth2 > Client ID & Client Secret
DISCORD_CLIENT_ID=your_discord_client_id
DISCORD_CLIENT_SECRET=your_discord_client_secret

# ─── Supabase ─────────────────────────────────────────────────────────────────
# Settings > API > Project URL
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co

# Settings > API > anon public key (pour les routes API server-side c'est ok)
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Settings > API > service_role key (pour les opérations admin seulement)
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ─── Admin ────────────────────────────────────────────────────────────────────
# Discord ID du gérant (clic droit sur votre profil > Copier l'identifiant)
ADMIN_DISCORD_ID=your_discord_user_id_here
